{
  "manifest_version": 2,
  "name": "Job Tracker",
  "version": "1.1",
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "browser_specific_settings": {
    "gecko": {
        "id": "jobtracker@yourdomain.com"
    }
},
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs-tracker/*"],
      "js": ["dist/sync_applied.js"]
    },
    {
      "matches": [
        "https://www.linkedin.com/jobs/*"
      ],
      "js": ["dist/sync_apply.js", "dist/match_job.js"]
    },
    {
      "matches": ["<all_urls>"],
      "js": ["dist/autofill.js", "dist/remember.js"]
    }
  ],
  "background": { "scripts": ["dist/background.js"] },
  "permissions": ["activeTab",
                  "contextMenus",
                  "tabs",
                  "alarms",
                  "http://localhost:8050/*",
                  "*://*/*"
                  ]
}