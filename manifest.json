{
  "manifest_version": 2,
  "browser_specific_settings": {
    "gecko": {
        "id": "jobtracker@yourdomain.com"
    }
},
  "name": "Job Tracker",
  "version": "1.0",
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs-tracker/*"],
      "js": ["dist/sync_applied.js"]
    },
    {
      "matches": [
        "https://www.linkedin.com/jobs/search/*",
        "https://www.linkedin.com/jobs/collections/recommended/*",
        "https://www.linkedin.com/jobs/view/*"
      ],
      "js": ["dist/sync_apply.js", "dist/match_job.js"]
    }
  ],
  "background": { "scripts": ["dist/background.js"] },
  "permissions": ["activeTab", "tabs", "alarms", "http://localhost:8050/*", "*://*/*"]
}