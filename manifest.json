{
  "manifest_version": 2,
  "name": "Job Tracker",
  "version": "1.0",
"content_scripts": [
  {
    "matches": ["https://www.linkedin.com/jobs-tracker/*"],
    "js": ["sync_applied.js"]
  }
],
  "background": { "scripts": ["background.js"] },
  "permissions": ["activeTab", "tabs", "alarms", "http://localhost:8050/*"]
}